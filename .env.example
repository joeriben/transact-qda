DATABASE_URL=postgresql://tqda:tqda_dev@localhost:5432/transact_qda
SESSION_SECRET=change-me-to-a-random-string

# First-run bootstrap: `auto` seeds admin/demo only on an empty database.
TQDA_BOOTSTRAP=auto

# Advanced runtime paths (normally only set by the local installer).
# TQDA_STATE_DIR=/var/lib/transact-qda
# TQDA_BRAND_DIR=/var/lib/transact-qda/brand

# Instance branding (optional; empty = public/neutral defaults).
# See static/brand/README.md.
PUBLIC_BRAND_LOGO_URL=
PUBLIC_BRAND_NAME=
PUBLIC_BRAND_LINK=
PUBLIC_IMPRESSUM_URL=
