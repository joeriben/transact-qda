SESSION_SECRET=change-me-to-a-random-string
TQDA_IMAGE=ghcr.io/joeriben/transact-qda:latest
TQDA_PORT=5174

# Optional host-side development only (not used by the official Compose runtime).
DATABASE_URL=postgresql://tqda:tqda_dev@localhost:5432/transact_qda

# Instance branding (optional; empty = public/neutral defaults).
# See static/brand/README.md for where to put the logo and impressum files.
PUBLIC_BRAND_LOGO_URL=
PUBLIC_BRAND_NAME=
PUBLIC_BRAND_LINK=
PUBLIC_IMPRESSUM_URL=
